# 9router LLM Gateway Configuration
NINE_ROUTER_API_KEY=your-9router-api-key-here
NINE_ROUTER_BASE_URL=http://9router:9000/v1
NINE_ROUTER_MODEL=gpt-4

# Better Auth Secret (session security)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-generated-secret-here-min-32-chars

# Optional: LangSmith Observability (for debugging)
# LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=your-langsmith-key

# Optional: Custom Package Mirrors (for restricted networks)
# NPM_REGISTRY=https://registry.npmmirror.com
# UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# Optional: Cloudflare Tunnel
# CLOUDFLARE_TUNNEL_URL=https://your-subdomain.example.com
